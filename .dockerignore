# Excluir archivos que NO son necesarios para el build

# Dependencies (se instalan con composer/npm en el build)
vendor/
node_modules/

# Archivos de entorno sensibles (se generat en docker-entrypoint.sh)
.env
.env.local
.env.staging
.env.production

# Git
.git/

# Assets compilados (se generan en el build)
public/build/css/
public/build/js/
public/build/img/

# Base de datos
*.sql
*.sqlite
*.db
*.dump

# Logs
*.log
logs/
log/

# Sistema operativo
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/

# Temporales
*.tmp
*.temp
*.bak
*.backup

# README (no necesario en producción)
README.md
